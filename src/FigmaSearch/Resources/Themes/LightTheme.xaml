<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background -->
    <SolidColorBrush x:Key="BgPrimary"    Color="#F5F5F5"/>
    <SolidColorBrush x:Key="BgSecondary"  Color="#EBEBEB"/>
    <SolidColorBrush x:Key="BgTertiary"   Color="#E0E0E0"/>
    <SolidColorBrush x:Key="BgHover"      Color="#D6D6D6"/>
    <SolidColorBrush x:Key="BgSelected"   Color="#CCE5FF"/>

    <!-- Foreground -->
    <SolidColorBrush x:Key="FgPrimary"    Color="#1E1E1E"/>
    <SolidColorBrush x:Key="FgSecondary"  Color="#555555"/>
    <SolidColorBrush x:Key="FgDisabled"   Color="#AAAAAA"/>
    <SolidColorBrush x:Key="FgTeamLabel"  Color="#888888"/>

    <!-- Accent -->
    <SolidColorBrush x:Key="AccentBlue"   Color="#0078D4"/>
    <SolidColorBrush x:Key="AccentHover"  Color="#106EBE"/>
    <SolidColorBrush x:Key="ErrorRed"     Color="#D32F2F"/>
    <SolidColorBrush x:Key="SuccessGreen" Color="#388E3C"/>
    <SolidColorBrush x:Key="WarningOrange" Color="#F57C00"/>

    <!-- Border -->
    <SolidColorBrush x:Key="BorderColor"  Color="#CCCCCC"/>

    <!-- Highlight keyword color -->
    <SolidColorBrush x:Key="KeywordColor" Color="#0078D4"/>

    <!-- Sync status bar backgrounds -->
    <SolidColorBrush x:Key="SyncProgressBg"  Color="#E3F2FD"/>
    <SolidColorBrush x:Key="SyncSuccessBg"   Color="#E8F5E9"/>
    <SolidColorBrush x:Key="SyncErrorBg"     Color="#FFEBEE"/>
    <SolidColorBrush x:Key="ErrorTextLight"  Color="#C62828"/>

    <!-- API error bar -->
    <SolidColorBrush x:Key="ApiErrorBg"      Color="#FFCDD2"/>
    <SolidColorBrush x:Key="ApiErrorFg"      Color="#B71C1C"/>
    <SolidColorBrush x:Key="ApiErrorBtn"     Color="#D32F2F"/>

    <!-- Update badge -->
    <SolidColorBrush x:Key="UpdateBadgeBg"   Color="#E53935"/>

    <!-- Scrollbar style -->
    <Style x:Key="DarkScrollBar" TargetType="ScrollBar">
        <Setter Property="Background" Value="{StaticResource BgSecondary}"/>
        <Setter Property="Foreground" Value="{StaticResource FgDisabled}"/>
        <Setter Property="Width" Value="6"/>
    </Style>

    <!-- Button style (flat) -->
    <Style x:Key="FlatButton" TargetType="Button">
        <Setter Property="Background"   Value="Transparent"/>
        <Setter Property="Foreground"   Value="{StaticResource FgSecondary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"      Value="6,2"/>
        <Setter Property="Cursor"       Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource BgHover}"/>
                            <Setter Property="Foreground" Value="{StaticResource FgPrimary}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource FgDisabled}"/>
                            <Setter Property="Cursor"     Value="Arrow"/>
                            <Setter Property="Opacity"    Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Update button style (accent) -->
    <Style x:Key="UpdateButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
        <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
        <Setter Property="FontSize"   Value="12"/>
    </Style>

    <!-- TextBox style -->
    <Style x:Key="SearchBox" TargetType="TextBox">
        <Setter Property="Background"       Value="{StaticResource BgTertiary}"/>
        <Setter Property="Foreground"       Value="{StaticResource FgPrimary}"/>
        <Setter Property="CaretBrush"       Value="{StaticResource FgPrimary}"/>
        <Setter Property="BorderBrush"      Value="Transparent"/>
        <Setter Property="BorderThickness"  Value="0"/>
        <Setter Property="Padding"          Value="10,8"/>
        <Setter Property="FontSize"         Value="15"/>
        <Setter Property="SelectionBrush"   Value="{StaticResource AccentBlue}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== SearchBox with placeholder watermark ===== -->
    <Style x:Key="SearchBoxWithHint" TargetType="TextBox" BasedOn="{StaticResource SearchBox}">
        <Style.Resources>
            <VisualBrush x:Key="HintBrush" AlignmentX="Left" AlignmentY="Center" Stretch="None">
                <VisualBrush.Visual>
                    <TextBlock Text="搜索 Figma 文档..."
                               Foreground="{StaticResource FgDisabled}" FontSize="15" Margin="2,0,0,0"/>
                </VisualBrush.Visual>
            </VisualBrush>
        </Style.Resources>
        <Style.Triggers>
            <Trigger Property="Text" Value="">
                <Setter Property="Background" Value="{StaticResource HintBrush}"/>
            </Trigger>
            <Trigger Property="Text" Value="{x:Null}">
                <Setter Property="Background" Value="{StaticResource HintBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ===== DataGrid light style ===== -->
    <Style TargetType="DataGrid">
        <Setter Property="Background"           Value="{StaticResource BgTertiary}"/>
        <Setter Property="Foreground"           Value="{StaticResource FgPrimary}"/>
        <Setter Property="BorderBrush"          Value="{StaticResource BorderColor}"/>
        <Setter Property="BorderThickness"      Value="1"/>
        <Setter Property="RowBackground"        Value="{StaticResource BgTertiary}"/>
        <Setter Property="AlternatingRowBackground" Value="{StaticResource BgSecondary}"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderColor}"/>
        <Setter Property="VerticalGridLinesBrush"   Value="{StaticResource BorderColor}"/>
        <Setter Property="GridLinesVisibility"  Value="Horizontal"/>
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background"    Value="{StaticResource BgSecondary}"/>
        <Setter Property="Foreground"    Value="{StaticResource FgSecondary}"/>
        <Setter Property="FontSize"      Value="11"/>
        <Setter Property="FontWeight"    Value="SemiBold"/>
        <Setter Property="Padding"       Value="10,6"/>
        <Setter Property="BorderBrush"   Value="{StaticResource BorderColor}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="SeparatorBrush" Value="{StaticResource BorderColor}"/>
    </Style>

    <Style TargetType="DataGridRow">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource FgPrimary}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource BgHover}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource BgSelected}"/>
                <Setter Property="Foreground" Value="{StaticResource FgPrimary}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="BorderBrush"     Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"         Value="8,4"/>
        <Setter Property="Foreground"      Value="{StaticResource FgPrimary}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource FgPrimary}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ===== ScrollViewer style ===== -->
    <Style TargetType="ScrollViewer">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <!-- ===== PasswordBox light style ===== -->
    <Style TargetType="PasswordBox">
        <Setter Property="Background"      Value="{StaticResource BgTertiary}"/>
        <Setter Property="Foreground"      Value="{StaticResource FgPrimary}"/>
        <Setter Property="CaretBrush"      Value="{StaticResource FgPrimary}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BorderColor}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="10,8"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="SelectionBrush"  Value="{StaticResource AccentBlue}"/>
    </Style>

    <!-- ===== CheckBox light style ===== -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground"  Value="{StaticResource FgPrimary}"/>
        <Setter Property="FontSize"    Value="13"/>
    </Style>

    <!-- ===== Slider light style ===== -->
    <Style TargetType="Slider">
        <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
    </Style>

    <!-- ===== ToolTip light style ===== -->
    <Style TargetType="ToolTip">
        <Setter Property="Background"  Value="{StaticResource BgTertiary}"/>
        <Setter Property="Foreground"  Value="{StaticResource FgPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
    </Style>

</ResourceDictionary>
