<Window x:Class="FigmaSearch.Windows.SearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:FigmaSearch.Controls"
        Title="肥姑妈搜" WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize"
        ShowInTaskbar="False" Topmost="True"
        Width="640" SizeToContent="Height"
        WindowStartupLocation="Manual"
        Deactivated="Window_Deactivated" KeyDown="Window_KeyDown">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
        <Style x:Key="AiHyperlinkStyle" TargetType="Hyperlink">
            <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
            <Setter Property="TextDecorations" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="TextDecorations" Value="Underline"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Border Background="{DynamicResource BgPrimary}"
            BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="8" Color="#000000" Opacity="0.6" Direction="270"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <!-- Search bar -->
            <Grid Grid.Row="0" Margin="14,0,14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="&#128269;" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="16" Opacity="0.5"/>
                <TextBox x:Name="SearchBox" Grid.Column="1" Style="{DynamicResource SearchBoxWithHint}"
                         Background="Transparent" TextChanged="SearchBox_TextChanged"/>
                <Button x:Name="AskAiBtn" Grid.Column="2" Content="问 AI" Margin="6,0,0,0"
                        Style="{DynamicResource FlatButton}" Background="{DynamicResource BgTertiary}"
                        Foreground="{DynamicResource AccentBlue}" Padding="10,6" FontSize="12"
                        VerticalAlignment="Center" Click="AskAi_Click"
                        ToolTip="将搜索框内容发送给 AI 助手"/>
                <Button x:Name="UpdateBtn" Grid.Column="3" Style="{DynamicResource UpdateButton}"
                        Visibility="Collapsed" Click="UpdateBtn_Click" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#26356;&#26032; "/>
                        <Border Background="{DynamicResource UpdateBadgeBg}" CornerRadius="6" Padding="4,1" VerticalAlignment="Center">
                            <TextBlock Text="NEW" FontSize="9" Foreground="White" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                </Button>
            </Grid>
            <!-- API Key error bar -->
            <Border x:Name="ApiErrorBar" Grid.Row="1" Background="{DynamicResource ApiErrorBg}" Visibility="Collapsed" Padding="14,7">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="API Key &#24050;&#22833;&#25928;&#65292;&#35831;&#26356;&#26032;&#21518;&#37325;&#35797;" Foreground="{DynamicResource ApiErrorFg}" VerticalAlignment="Center" FontSize="12"/>
                    <Button Grid.Column="1" Content="&#21069;&#24448;&#35774;&#32622;" Style="{DynamicResource FlatButton}" Foreground="{DynamicResource ApiErrorBtn}" Click="ApiErrorGotoSettings_Click"/>
                </Grid>
            </Border>
            <!-- Results -->
            <Border x:Name="ResultsArea" Grid.Row="2" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border x:Name="AiReadyBanner" Background="{DynamicResource BgTertiary}" Padding="14,6" Visibility="Collapsed">
                        <Button x:Name="AiReadyButton" Content="AI 回答就绪 ▸"
                                Style="{DynamicResource FlatButton}" Foreground="{DynamicResource AccentBlue}"
                                HorizontalAlignment="Left" Padding="0" Click="AiReadyBanner_Click"/>
                    </Border>
                    <ScrollViewer x:Name="ResultsScroll" Grid.Row="1" MaxHeight="520"
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="ResultsScroll_PreviewMouseWheel">
                        <StackPanel x:Name="ResultsPanel" Margin="0,6,0,8"/>
                    </ScrollViewer>
                    <!-- Result count hint -->
                    <Border x:Name="ResultCountBar" Grid.Row="2" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0"
                            Padding="14,5" Visibility="Collapsed">
                        <TextBlock x:Name="ResultCountText" HorizontalAlignment="Center"
                                   FontSize="11" Foreground="{DynamicResource FgSecondary}"/>
                    </Border>
                </Grid>
            </Border>
            <!-- AI response area (replaces search results when active) -->
            <Border x:Name="AiResultArea" Grid.Row="2" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="16,10,12,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="AI 回答" FontSize="12" Foreground="{DynamicResource FgSecondary}" VerticalAlignment="Center"/>
                            <Button x:Name="AiDismissButton" Grid.Column="1" Content="✕"
                                    Style="{DynamicResource FlatButton}" Foreground="{DynamicResource FgSecondary}"
                                    Padding="6,2" Click="AiDismissButton_Click"/>
                        </Grid>
                    </Border>
                    <!-- AI loading indicator (shown while waiting for response) -->
                    <Border x:Name="AiLoadingIndicator" Grid.Row="1" Padding="16,20,16,20" Visibility="Collapsed">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                                <Ellipse x:Name="Dot1" Width="8" Height="8" Fill="{DynamicResource AccentBlue}" Opacity="0.3" Margin="0,0,6,0"/>
                                <Ellipse x:Name="Dot2" Width="8" Height="8" Fill="{DynamicResource AccentBlue}" Opacity="0.3" Margin="0,0,6,0"/>
                                <Ellipse x:Name="Dot3" Width="8" Height="8" Fill="{DynamicResource AccentBlue}" Opacity="0.3"/>
                            </StackPanel>
                            <TextBlock x:Name="AiStatusLabel" Text="AI 正在思考…" FontSize="12"
                                       Foreground="{DynamicResource FgSecondary}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <!-- AI response content (shown after response received) -->
                    <ScrollViewer x:Name="AiResponseScroll" Grid.Row="1" MaxHeight="520" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="ResultsScroll_PreviewMouseWheel" Visibility="Collapsed">
                        <StackPanel Margin="16,8,16,14">
                            <TextBlock x:Name="AiResponseText" TextWrapping="Wrap" FontSize="13"
                                       Foreground="{DynamicResource FgPrimary}" LineHeight="22"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
            <!-- Sync status bar (progress / error) -->
            <Border x:Name="SyncStatusBar" Grid.Row="3" Visibility="Collapsed" Padding="14,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="SyncStatusIcon" Grid.Column="0" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="SyncStatusText" Grid.Column="1" FontSize="11" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
