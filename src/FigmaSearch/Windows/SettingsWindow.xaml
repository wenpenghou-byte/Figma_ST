<Window x:Class="FigmaSearch.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="肥姑妈搜 - 设置" Width="680" Height="600"
        WindowStyle="SingleBorderWindow" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgPrimary}"
        Foreground="{StaticResource FgPrimary}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="设置" FontSize="20" FontWeight="Bold"
                   Foreground="{StaticResource FgPrimary}" Margin="0,0,0,20"/>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- API Key -->
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Figma API Key" Foreground="{StaticResource FgSecondary}" FontSize="12" Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <PasswordBox x:Name="ApiKeyBox" Background="{StaticResource BgTertiary}"
                                     Foreground="{StaticResource FgPrimary}" BorderBrush="{StaticResource BorderColor}"
                                     Padding="10,8" FontSize="13" PasswordChanged="ApiKeyBox_Changed"/>
                        <Button Grid.Column="1" Content="验证" Margin="8,0,0,0"
                                Style="{StaticResource FlatButton}" Background="{StaticResource BgTertiary}"
                                Foreground="{StaticResource FgPrimary}" Padding="12,8" Click="ValidateApiKey_Click"/>
                        <Button Grid.Column="2" Content="?" Margin="4,0,0,0"
                                Style="{StaticResource FlatButton}" Background="{StaticResource BgTertiary}"
                                Foreground="{StaticResource FgSecondary}" Padding="10,8"
                                ToolTip="如何获取 API Key？" Click="ApiKeyHelp_Click"/>
                    </Grid>
                    <TextBlock x:Name="ApiKeyStatus" FontSize="11" Margin="0,4,0,0" Visibility="Collapsed"/>
                </StackPanel>
                <!-- Teams -->
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Team IDs" Foreground="{StaticResource FgSecondary}" FontSize="12" Margin="0,0,0,6"/>
                    <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="4">
                        <StackPanel>
                            <DataGrid x:Name="TeamsGrid" Background="{StaticResource BgTertiary}"
                                      Foreground="{StaticResource FgPrimary}" BorderThickness="0"
                                      RowBackground="{StaticResource BgTertiary}"
                                      AlternatingRowBackground="{StaticResource BgSecondary}"
                                      GridLinesVisibility="None" HeadersVisibility="Column"
                                      AutoGenerateColumns="False" CanUserAddRows="False"
                                      MinHeight="60" MaxHeight="180">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Team ID" Binding="{Binding TeamId}" Width="*"/>
                                    <DataGridTextColumn Header="显示名称" Binding="{Binding DisplayName}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <Grid Margin="8,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="NewTeamId" Grid.Column="0" Margin="0,0,4,0"
                                         Style="{StaticResource SearchBox}" FontSize="13"
                                         TextChanged="NewTeam_TextChanged"/>
                                <TextBox x:Name="NewTeamName" Grid.Column="1" Margin="0,0,4,0"
                                         Style="{StaticResource SearchBox}" FontSize="13"
                                         TextChanged="NewTeam_TextChanged"/>
                                <Button x:Name="AddTeamBtn" Grid.Column="2" Content="写入" Margin="0,0,4,0"
                                        Style="{StaticResource FlatButton}" Background="{StaticResource BgHover}"
                                        Padding="12,6" IsEnabled="False" Click="AddTeam_Click"/>
                                <Button Grid.Column="3" Content="删除选中"
                                        Style="{StaticResource FlatButton}" Background="{StaticResource BgHover}"
                                        Padding="12,6" Click="RemoveTeam_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
                <!-- Interval -->
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="自动更新间隔（小时）" Foreground="{StaticResource FgSecondary}" FontSize="12" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal">
                        <Slider x:Name="IntervalSlider" Minimum="6" Maximum="168" Value="48" Width="280"
                                VerticalAlignment="Center" ValueChanged="IntervalSlider_Changed"/>
                        <TextBlock x:Name="IntervalLabel" Text="48 小时" Margin="12,0,0,0"
                                   Foreground="{StaticResource FgPrimary}" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
                <!-- Startup -->
                <CheckBox x:Name="StartupCheck" Content="开机启动"
                          Foreground="{StaticResource FgPrimary}" Margin="0,0,0,16"
                          Checked="StartupCheck_Changed" Unchecked="StartupCheck_Changed"/>
                <!-- Theme -->
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="界面主题" Foreground="{StaticResource FgSecondary}" FontSize="12" Margin="0,0,0,6"/>
                    <ComboBox x:Name="ThemeCombo" Width="160" HorizontalAlignment="Left"
                              SelectionChanged="ThemeCombo_Changed">
                        <ComboBoxItem Content="深色" Tag="Dark"/>
                        <ComboBoxItem Content="浅色" Tag="Light"/>
                    </ComboBox>
                </StackPanel>
                <!-- Hotkey -->
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="唤醒搜索框快捷键" Foreground="{StaticResource FgSecondary}" FontSize="12" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="HotkeyBox" Width="200" IsReadOnly="True" Cursor="Hand"
                                 Style="{StaticResource SearchBox}" FontSize="13" TextAlignment="Center"
                                 PreviewKeyDown="HotkeyBox_PreviewKeyDown" GotFocus="HotkeyBox_GotFocus" LostFocus="HotkeyBox_LostFocus"/>
                        <Button Content="恢复默认" Margin="8,0,0,0"
                                Style="{StaticResource FlatButton}" Background="{StaticResource BgTertiary}"
                                Padding="12,8" Click="HotkeyReset_Click"/>
                    </StackPanel>
                    <TextBlock x:Name="HotkeyHint" Text="点击输入框后按下快捷键组合（需含 Ctrl/Alt/Shift 修饰键）"
                               Foreground="{StaticResource FgDisabled}" FontSize="11" Margin="0,4,0,0"/>
                </StackPanel>
                <!-- Manual sync -->
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="文档信息" Foreground="{StaticResource FgSecondary}" FontSize="12" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="立即同步文档" Style="{StaticResource FlatButton}"
                                Background="{StaticResource BgHover}" Padding="14,8" Click="ManualSync_Click"/>
                        <TextBlock x:Name="SyncStatus" Margin="12,0,0,0"
                                   Foreground="{StaticResource FgSecondary}" VerticalAlignment="Center" FontSize="12"/>
                    </StackPanel>
                    <TextBlock x:Name="DbStats" Foreground="{StaticResource FgDisabled}" FontSize="11" Margin="0,8,0,0"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="取消" Style="{StaticResource FlatButton}"
                    Background="{StaticResource BgTertiary}" Padding="20,8" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="保存" Style="{StaticResource FlatButton}"
                    Background="{StaticResource AccentBlue}" Foreground="White" Padding="20,8" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
