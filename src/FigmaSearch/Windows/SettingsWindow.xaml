<Window x:Class="FigmaSearch.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="肥姑妈搜 - 设置" Width="680" Height="600"
        WindowStyle="SingleBorderWindow" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgPrimary}"
        Foreground="{StaticResource FgPrimary}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="设置" FontSize="20" FontWeight="Bold"
                   Foreground="{StaticResource FgPrimary}" Margin="0,0,0,20"/>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- API Key -->
                <StackPanel Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Figma API Key" Foreground="{StaticResource FgSecondary}" FontSize="12"/>
                        <Button Content="?" Margin="6,0,0,0"
                                Style="{StaticResource FlatButton}" Background="{StaticResource BgTertiary}"
                                Foreground="{StaticResource FgSecondary}" Padding="6,1" FontSize="11"
                                ToolTip="如何获取 API Key？" Click="ApiKeyHelp_Click"/>
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <PasswordBox x:Name="ApiKeyBox" Background="{StaticResource BgTertiary}"
                                     Foreground="{StaticResource FgPrimary}" BorderBrush="{StaticResource BorderColor}"
                                     Padding="10,8" FontSize="13" PasswordChanged="ApiKeyBox_Changed"/>
                        <Button Grid.Column="1" Content="验证" Margin="8,0,0,0"
                                Style="{StaticResource FlatButton}" Background="{StaticResource BgTertiary}"
                                Foreground="{StaticResource FgPrimary}" Padding="12,8" Click="ValidateApiKey_Click"/>
                    </Grid>
                    <TextBlock x:Name="ApiKeyStatus" FontSize="11" Margin="0,4,0,0" Visibility="Collapsed"/>
                </StackPanel>
                <!-- Teams -->
                <StackPanel Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Team IDs" Foreground="{StaticResource FgSecondary}" FontSize="12"/>
                        <Button Content="?" Margin="6,0,0,0"
                                Style="{StaticResource FlatButton}" Background="{StaticResource BgTertiary}"
                                Foreground="{StaticResource FgSecondary}" Padding="6,1" FontSize="11"
                                ToolTip="如何获取 Team ID？" Click="TeamIdHelp_Click"/>
                    </StackPanel>
                    <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="4"
                            Background="{StaticResource BgTertiary}" Padding="0">
                        <StackPanel>
                            <!-- Column headers -->
                            <Grid Margin="10,8,10,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Team ID" Foreground="{StaticResource FgSecondary}" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="显示名称" Foreground="{StaticResource FgSecondary}" FontSize="11" FontWeight="SemiBold" Margin="4,0,0,0"/>
                                <TextBlock Grid.Column="2" Text="独立 API Key（可选）" Foreground="{StaticResource FgSecondary}" FontSize="11" FontWeight="SemiBold" Margin="4,0,0,0"/>
                            </Grid>
                            <!-- Existing teams (editable rows) -->
                            <ItemsControl x:Name="TeamsItemsControl" MinHeight="0" MaxHeight="260">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="8,3,8,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="76"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding TeamId, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                     Style="{StaticResource SearchBox}" FontSize="12" Padding="6,6" Margin="0,0,4,0"
                                                     Background="{StaticResource BgSecondary}"
                                                     LostFocus="TeamRow_LostFocus"/>
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding DisplayName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                     Style="{StaticResource SearchBox}" FontSize="12" Padding="6,6" Margin="0,0,4,0"
                                                     Background="{StaticResource BgSecondary}"
                                                     LostFocus="TeamRow_LostFocus"/>
                                            <PasswordBox Grid.Column="2" Tag="{Binding}" Padding="6,6" FontSize="12" Margin="0,0,4,0"
                                                         Background="{StaticResource BgSecondary}" Foreground="{StaticResource FgPrimary}"
                                                         BorderBrush="Transparent" BorderThickness="0"
                                                         PasswordChanged="TeamApiKey_PasswordChanged"/>
                                            <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Button Content="▲" Style="{StaticResource FlatButton}" Padding="5,4" FontSize="10"
                                                        ToolTip="上移" Tag="{Binding}" Click="MoveTeamUp_Click"/>
                                                <Button Content="▼" Style="{StaticResource FlatButton}" Padding="5,4" FontSize="10"
                                                        ToolTip="下移" Tag="{Binding}" Click="MoveTeamDown_Click"/>
                                                <Button Content="✕" Style="{StaticResource FlatButton}" Padding="5,4" FontSize="10"
                                                        Foreground="{StaticResource ErrorRed}" ToolTip="删除"
                                                        Tag="{Binding}" Click="RemoveTeam_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <!-- Add row button -->
                            <Button x:Name="AddTeamBtn" Content="＋ 添加一行" Margin="8,4,8,8"
                                    Style="{StaticResource FlatButton}" Background="{StaticResource BgSecondary}"
                                    Foreground="{StaticResource FgSecondary}" Padding="0,8"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                    FontSize="12" Click="AddTeam_Click"/>
                        </StackPanel>
                    </Border>
                    <TextBlock Foreground="{StaticResource FgDisabled}" FontSize="11" Margin="0,4,0,0"
                               Text="Team ID 为纯数字，可从 Figma 团队页面 URL 中获取（如 figma.com/files/team/数字ID）"/>
                    <TextBlock x:Name="TeamIdError" Foreground="OrangeRed" FontSize="11" Margin="0,2,0,0"
                               Visibility="Collapsed" TextWrapping="Wrap"/>
                    <TextBlock Foreground="{StaticResource FgDisabled}" FontSize="11" Margin="0,2,0,0"
                               Text="列表顺序决定搜索结果的 Team 展示优先级，排在前面的 Team 优先显示。"/>
                    <TextBlock Foreground="{StaticResource FgDisabled}" FontSize="11" Margin="0,2,0,0" TextWrapping="Wrap"
                               Text="💡 独立 API Key：如果某个 Team 的文档同步不完整（如页面缺失），可能是因为当前 API Key 对该 Team 仅有查看权限。可以找该 Team 中有编辑权限的同事生成一个 Personal Access Token，填入「独立 API Key」列即可。留空则使用上方的全局 Key。已保存的 Key 不会因留空而被删除。"/>
                </StackPanel>
                <!-- Interval + Manual sync -->
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="文档数据同步" Foreground="{StaticResource FgSecondary}" FontSize="12" Margin="0,0,0,6"/>
                    <!-- Auto interval -->
                    <TextBlock Text="自动同步间隔" Foreground="{StaticResource FgPrimary}" FontSize="12" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Slider x:Name="IntervalSlider" Minimum="6" Maximum="168" Value="48" Width="280"
                                VerticalAlignment="Center" ValueChanged="IntervalSlider_Changed"/>
                        <TextBlock x:Name="IntervalLabel" Text="48 小时" Margin="12,0,0,0"
                                   Foreground="{StaticResource FgPrimary}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Foreground="{StaticResource FgDisabled}" FontSize="11" Margin="0,0,0,2"
                               Text="程序在后台按此间隔自动拉取 Figma 最新文档数据。"/>
                    <TextBlock Foreground="{StaticResource FgDisabled}" FontSize="11" Margin="0,0,0,12"
                               Text="⚠ 仅拥有 view 权限的 Team 建议关闭自动同步（设为最大值），改用下方手动同步。"/>
                    <!-- Manual sync -->
                    <TextBlock Text="手动同步" Foreground="{StaticResource FgPrimary}" FontSize="12" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="立即同步文档" Style="{StaticResource FlatButton}"
                                Background="{StaticResource BgHover}" Padding="14,8" Click="ManualSync_Click"/>
                        <TextBlock x:Name="SyncStatus" Margin="12,0,0,0"
                                   Foreground="{StaticResource FgSecondary}" VerticalAlignment="Center" FontSize="12"/>
                    </StackPanel>
                    <TextBlock x:Name="DbStats" Foreground="{StaticResource FgDisabled}" FontSize="11" Margin="0,8,0,0"/>
                </StackPanel>
                <!-- Open in browser -->
                <CheckBox x:Name="OpenInBrowserCheck" Content="使用浏览器打开 Figma 链接（而非桌面客户端）"
                          Foreground="{StaticResource FgPrimary}" Margin="0,0,0,4"
                          Checked="OpenInBrowserCheck_Changed" Unchecked="OpenInBrowserCheck_Changed"/>
                <TextBlock Foreground="{StaticResource FgDisabled}" FontSize="11" Margin="18,0,0,16"
                           Text="如果 Figma 桌面客户端打开后白屏，可开启此选项改用浏览器打开"/>
                <!-- Startup -->
                <CheckBox x:Name="StartupCheck" Content="开机启动"
                          Foreground="{StaticResource FgPrimary}" Margin="0,0,0,16"
                          Checked="StartupCheck_Changed" Unchecked="StartupCheck_Changed"/>
                <!-- Theme -->
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="界面主题" Foreground="{StaticResource FgSecondary}" FontSize="12" Margin="0,0,0,6"/>
                    <ComboBox x:Name="ThemeCombo" Width="160" HorizontalAlignment="Left"
                              SelectionChanged="ThemeCombo_Changed">
                        <ComboBoxItem Content="深色" Tag="Dark"/>
                        <ComboBoxItem Content="浅色" Tag="Light"/>
                    </ComboBox>
                </StackPanel>
                <!-- Hotkey -->
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="唤醒搜索框快捷键" Foreground="{StaticResource FgSecondary}" FontSize="12" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="HotkeyBox" Width="200" IsReadOnly="True" Cursor="Hand"
                                 Style="{StaticResource SearchBox}" FontSize="13" TextAlignment="Center"
                                 PreviewKeyDown="HotkeyBox_PreviewKeyDown" GotFocus="HotkeyBox_GotFocus" LostFocus="HotkeyBox_LostFocus"/>
                        <Button Content="恢复默认" Margin="8,0,0,0"
                                Style="{StaticResource FlatButton}" Background="{StaticResource BgTertiary}"
                                Padding="12,8" Click="HotkeyReset_Click"/>
                    </StackPanel>
                    <TextBlock x:Name="HotkeyHint" Text="点击输入框后按下快捷键组合（需含 Ctrl/Alt/Shift 修饰键）"
                               Foreground="{StaticResource FgDisabled}" FontSize="11" Margin="0,4,0,0"/>
                </StackPanel>
                <!-- Check for updates -->
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="应用更新" Foreground="{StaticResource FgSecondary}" FontSize="12" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="CheckUpdateBtn" Content="检查更新" Style="{StaticResource FlatButton}"
                                Background="{StaticResource BgHover}" Padding="14,8" Click="CheckUpdate_Click"/>
                        <Button x:Name="InstallUpdateBtn" Visibility="Collapsed" Style="{StaticResource FlatButton}"
                                Background="{StaticResource AccentBlue}" Foreground="White" Padding="14,8" Click="InstallUpdate_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="立即更新 "/>
                                <Border Background="#E8443A" CornerRadius="6" Padding="4,1" VerticalAlignment="Center">
                                    <TextBlock Text="NEW" FontSize="9" Foreground="White" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                        </Button>
                        <TextBlock x:Name="UpdateStatus" Margin="12,0,0,0"
                                   Foreground="{StaticResource FgSecondary}" VerticalAlignment="Center" FontSize="12"/>
                    </StackPanel>
                    <TextBlock x:Name="VersionLabel" Foreground="{StaticResource FgDisabled}" FontSize="11" Margin="0,8,0,0"/>
                </StackPanel>
                <!-- Contact -->
                <StackPanel Margin="0,0,0,8">
                    <TextBlock Text="问题反馈" Foreground="{StaticResource FgSecondary}" FontSize="12" Margin="0,0,0,6"/>
                    <TextBlock Foreground="{StaticResource FgDisabled}" FontSize="12">
                        问题反馈：<Hyperlink NavigateUri="mailto:houwenpeng@corp.netease.com"
                                             RequestNavigate="ContactLink_RequestNavigate"
                                             Foreground="{StaticResource AccentBlue}">houwenpeng@corp.netease.com</Hyperlink>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="取消" Style="{StaticResource FlatButton}"
                    Background="{StaticResource BgTertiary}" Padding="20,8" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="保存" Style="{StaticResource FlatButton}"
                    Background="{StaticResource AccentBlue}" Foreground="White" Padding="20,8" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
