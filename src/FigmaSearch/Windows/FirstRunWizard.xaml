<Window x:Class="FigmaSearch.Windows.FirstRunWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="肥姑妈搜 - 初始配置" Width="500" Height="560"
        WindowStyle="SingleBorderWindow" ResizeMode="CanMinimize"
        ShowInTaskbar="True"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgPrimary}" Foreground="{StaticResource FgPrimary}">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="欢迎使用肥姑妈搜" FontSize="22" FontWeight="Bold"
                   Foreground="{StaticResource FgPrimary}" Margin="0,0,0,8"/>
        <TextBlock Grid.Row="1" TextWrapping="Wrap" Margin="0,0,0,24"
                   Foreground="{StaticResource FgSecondary}" FontSize="13">
            请配置您的 Figma 信息以开始使用。如果没有 API Key，请前往 Figma 账户设置 → Security → Personal access tokens 获取。
        </TextBlock>
        <StackPanel Grid.Row="2">
            <!-- API Key -->
            <TextBlock Text="Figma API Key" Foreground="{StaticResource FgSecondary}" FontSize="12" Margin="0,0,0,6"/>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <PasswordBox x:Name="ApiKeyBox" Grid.Column="0" Background="{StaticResource BgTertiary}"
                             Foreground="{StaticResource FgPrimary}" BorderBrush="{StaticResource BorderColor}"
                             Padding="10,8" FontSize="13"/>
                <Button Grid.Column="1" Content="?" Margin="6,0,0,0"
                        Style="{StaticResource FlatButton}" Background="{StaticResource BgTertiary}"
                        Foreground="{StaticResource FgSecondary}" Padding="10,8"
                        ToolTip="如何获取 API Key？" Click="ApiKeyHelp_Click"/>
            </Grid>
            <TextBlock x:Name="ApiKeyHint" Text="请输入 API Key" Foreground="{StaticResource FgDisabled}"
                       FontSize="11" Margin="0,0,0,20"/>
            <!-- Teams -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Team ID + 显示名称" Foreground="{StaticResource FgSecondary}" FontSize="12"/>
                <Button Content="?" Margin="6,0,0,0"
                        Style="{StaticResource FlatButton}" Background="{StaticResource BgTertiary}"
                        Foreground="{StaticResource FgSecondary}" Padding="6,1" FontSize="11"
                        ToolTip="如何获取 Team ID？" Click="TeamIdHelp_Click"/>
            </StackPanel>
            <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="4" Margin="0,0,0,8">
                <StackPanel>
                    <DataGrid x:Name="TeamsGrid" Background="{StaticResource BgTertiary}"
                              Foreground="{StaticResource FgPrimary}" BorderThickness="0"
                              RowBackground="{StaticResource BgTertiary}"
                              AlternatingRowBackground="{StaticResource BgSecondary}"
                              GridLinesVisibility="None" HeadersVisibility="Column"
                              AutoGenerateColumns="False" CanUserAddRows="False"
                              MinHeight="60" MaxHeight="120">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Team ID" Binding="{Binding TeamId}" Width="*"/>
                            <DataGridTextColumn Header="显示名称" Binding="{Binding DisplayName}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Grid Margin="8,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="NewTeamId" Grid.Column="0" Margin="0,0,4,0"
                                 Style="{StaticResource SearchBox}" FontSize="13"
                                 TextChanged="NewTeam_TextChanged"/>
                        <TextBox x:Name="NewTeamName" Grid.Column="1" Margin="0,0,4,0"
                                 Style="{StaticResource SearchBox}" FontSize="13"
                                 TextChanged="NewTeam_TextChanged"/>
                        <Button x:Name="AddTeamBtn" Grid.Column="2" Content="写入"
                                Style="{StaticResource FlatButton}" Background="{StaticResource BgHover}"
                                Padding="12,6" IsEnabled="False" Click="AddTeam_Click"/>
                    </Grid>
                </StackPanel>
            </Border>
            <TextBlock x:Name="TeamIdHint" Foreground="{StaticResource FgDisabled}" FontSize="11" Margin="0,0,0,2"
                       Text="Team ID 为纯数字，可从 Figma 团队页面 URL 中获取（如 figma.com/files/team/数字ID）" TextWrapping="Wrap"/>
            <TextBlock x:Name="TeamIdError" Foreground="OrangeRed" FontSize="11" Margin="0,0,0,8"
                       Visibility="Collapsed" TextWrapping="Wrap"/>
            <!-- Startup checkbox -->
            <CheckBox x:Name="StartupCheck" Content="开机自动启动"
                      Foreground="{StaticResource FgPrimary}" IsChecked="True" Margin="0,8,0,0"/>
        </StackPanel>
        <!-- Bottom -->
        <StackPanel Grid.Row="3" Margin="0,20,0,0">
            <TextBlock x:Name="SyncStatus" Visibility="Collapsed"
                       Foreground="{StaticResource AccentBlue}" FontSize="12"
                       TextWrapping="Wrap" Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="SkipButton" Content="退出" Style="{StaticResource FlatButton}"
                        Background="{StaticResource BgTertiary}" Padding="20,8" Margin="0,0,8,0" Click="Skip_Click"/>
                <Button x:Name="StartButton" Content="开始使用 →" Style="{StaticResource FlatButton}"
                        Background="{StaticResource AccentBlue}" Foreground="White" Padding="20,8" Click="Start_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
